{
  "name": "spec-driven-docs-infra",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "description": "生成AI時代のドキュメント基盤",
  "scripts": {
    "postinstall": "uv sync && pnpm exec rulesync generate",
    "marp": "marp -s docs/スライド",
    "marp:build": "marp --input-dir docs/スライド --output docs/スライド --html --allow-local-files",
    "mkdocs": "uv run mkdocs serve --livereload",
    "mkdocs:build": "RENDER_SVG=1 RENDER_PNG=1 ENABLE_PDF=1 uv run mkdocs build",
    "lint:text": "textlint README.md \"docs/**/*.md\"",
    "lint:text:fix": "textlint --fix README.md \"docs/**/*.md\""
  },
  "devDependencies": {
    "@antfu/ni": "^30.1.0",
    "@github/copilot": "^1.0.39",
    "@marp-team/marp-cli": "^4.3.1",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@openai/codex": "^0.125.0",
    "rulesync": "^8.14.0",
    "textlint": "^15.6.0",
    "textlint-filter-rule-allowlist": "^4.0.0",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-no-mix-dearu-desumasu": "^6.0.4",
    "textlint-rule-preset-icsmedia": "github:ics-creative/textlint-rule-preset-icsmedia",
    "textlint-rule-preset-ja-spacing": "^2.4.3",
    "textlint-rule-preset-japanese": "^10.0.4",
    "textlint-rule-preset-jtf-style": "^3.0.3",
    "textlint-rule-prh": "^6.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer"
    ]
  }
}
